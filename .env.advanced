# Advanced Sales AI Platform Configuration
# Copy this to .env.local and update with your values

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite (Development - Default)
DATABASE_URL=sqlite:///./database.db

# PostgreSQL (Production - Recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/neuralbί_db

# MySQL (Alternative)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/neuralbί_db

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_password

# ============================================================================
# Celery Configuration (Task Queue)
# ============================================================================
CELERY_BROKER_URL=redis://default:redis_password@localhost:6379/0
CELERY_RESULT_BACKEND=redis://default:redis_password@localhost:6379/1

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345678
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ============================================================================
# API Configuration
# ============================================================================
API_VERSION=3.7
ENVIRONMENT=development  # development, staging, production
DEBUG=True  # Set to False in production

# ============================================================================
# Monitoring & Logging
# ============================================================================
SENTRY_DSN=  # Leave empty if not using Sentry
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or plain

# ============================================================================
# External APIs
# ============================================================================
GOOGLE_GENAI_API_KEY=your_google_genai_key
OLLAMA_API_URL=http://localhost:11434

# ============================================================================
# Billing & Tax Compliance
# ============================================================================
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_ENTERPRISE=
BILLING_LEGAL_ENTITY_NAME=NeuralBI Technologies Pvt Ltd
BUSINESS_GSTIN=27AAAAA0000A1Z5

# ============================================================================
# Email Configuration
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@neuralbί.ai

# ============================================================================
# AWS Configuration (if using AWS S3 for file storage)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=neuralbί-platform

# ============================================================================
# Azure Configuration (if using Azure Blob Storage)
# ============================================================================
AZURE_STORAGE_CONNECTION_STRING=

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Sales AI Platform
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_WEBSOCKET=true
FEATURE_REDIS_CACHE=true
FEATURE_CELERY_QUEUE=true
FEATURE_ADVANCED_MONITORING=true

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE_MB=500
ALLOWED_UPLOAD_TYPES=csv,xlsx,xls,json,parquet

# ============================================================================
# Deployment Configuration
# ============================================================================
PORT=8000
WORKERS=4
WORKER_TIMEOUT=120

# ============================================================================
# Development Only
# ============================================================================
# Set to True to reload on file changes
RELOAD=true

# Disable SSL verification for local development
VERIFY_SSL=false

# NeuralBI Enterprise Environment Variables

# --- AI Core ---
# Get one at: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key

# --- Database & Security ---
DB_PATH=./data.db
SECRET_KEY=INSECURE_DEV_KEY_CHANGE_IN_PRODUCTION # Generate with: openssl rand -hex 32

# --- Email Service (SMTP) ---
# Required for onboarding emails and invoice reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-app-password

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
STRIPE_SECRET_KEY=your-stripe-secret-key

# --- Meetings Provider ---
# Supported: jitsi (no key), daily (requires DAILY_API_KEY)
MEETING_PROVIDER=jitsi
DAILY_API_KEY=your-daily-api-key

# --- WhatsApp Business API ---
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_ID=123456789

# --- Business Details ---
BUSINESS_GSTIN=27AAAAA0000A1Z5

# --- Telemetry & Monitoring ---
# SENTRY_DSN=
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Launch Guards ---
ERP_SYNC_MODE=tally
ENABLE_DEMO_SEED_DATA=false
ENABLE_LIVE_KPI_SIMULATOR=false
NEURALBI_STRICT_PRODUCTION=true

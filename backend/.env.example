# NeuralBI Enterprise Environment Variables (Safe Template)

# --- Runtime ---
ENVIRONMENT=development
NEURALBI_STRICT_PRODUCTION=false
ENABLE_LIVE_KPI_SIMULATOR=false

# --- Database & Security ---
# Development fallback can remain sqlite, but strict production requires PostgreSQL.
DATABASE_URL=sqlite:///./app.db
SECRET_KEY=replace-with-a-strong-32-plus-char-secret

# --- Public CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AI Core ---
GOOGLE_API_KEY=replace-with-google-api-key

# --- Email Service (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password

# --- Payment Gateway (optional: Razorpay OR Stripe) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# --- Meetings Provider ---
# Supported: jitsi (no key), daily (requires DAILY_API_KEY)
MEETING_PROVIDER=jitsi
DAILY_API_KEY=

# --- ERP Integration (optional) ---
ERP_SYNC_MODE=
TALLY_URL=
ZOHO_CLIENT_ID=

# --- Monitoring ---
SENTRY_DSN=
PROMETHEUS_ENABLED=true

PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ==========================================
# FILE UPLOAD SETTINGS
# ==========================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=csv,xlsx,xls,json
UPLOAD_DIR=uploads/
TEMP_DIR=temp/

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ==========================================
# EXTERNAL APIs
# ==========================================
# Currency Exchange API
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# Business Intelligence APIs
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_AI_FEATURES=true
ENABLE_ERP_SYNC=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_REAL_TIME_UPDATES=true

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://neuralbi.vercel.app
CORS_ALLOW_CREDENTIALS=true

# Development Database (separate from production)
DEV_DATABASE_URL=sqlite:///data/neuralbi_dev.db

# ==========================================
# BACKUP & MAINTENANCE
# ==========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=backups/

# ==========================================
# PERFORMANCE TUNING
# ==========================================
CACHE_ENABLED=true
COMPRESSION_ENABLED=true
GZIP_COMPRESSION_LEVEL=6

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# ==========================================
# THIRD-PARTY INTEGRATIONS
# ==========================================
# Slack Integration
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_BOT_TOKEN=your-slack-bot-token

# Google Analytics

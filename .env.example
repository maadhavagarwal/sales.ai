# NeuralBI Platform - Environment Configuration

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=NeuralBI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-256-bit-secret-key-here-change-in-production

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Production: PostgreSQL
DATABASE_URL=postgresql://neuralbi:password@localhost:5432/neuralbi_prod

# Development: SQLite (fallback)
SQLITE_DB_PATH=data/neuralbi.db

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ==========================================
# REDIS CONFIGURATION (Optional)
# ==========================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ==========================================
# AI/ML CONFIGURATION
# ==========================================
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ML Model Settings
ML_MODEL_CACHE_DIR=models/
ML_BATCH_SIZE=32
ML_MAX_SEQUENCE_LENGTH=512

# ==========================================
# ERP INTEGRATION
# ==========================================
# Tally Integration
TALLY_URL=http://localhost:9000
TALLY_COMPANY=Demo Company
TALLY_USERNAME=admin
TALLY_PASSWORD=your-tally-password

# Zoho Books Integration
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_ORGANIZATION_ID=your-org-id

# Integration Mode: tally, zoho
ERP_SYNC_MODE=tally

# Launch guards (disable all demo/simulated behavior by default)
ENABLE_DEMO_SEED_DATA=false
ENABLE_LIVE_KPI_SIMULATOR=false
NEURALBI_STRICT_PRODUCTION=true
NEXT_PUBLIC_ENABLE_DEMO_MODE=false

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false

EMAIL_FROM=NeuralBI <noreply@neuralbi.com>
EMAIL_FROM_NAME=NeuralBI Platform

# Payments (live)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
STRIPE_SECRET_KEY=your-stripe-secret-key

# Meetings provider
MEETING_PROVIDER=jitsi
DAILY_API_KEY=your-daily-api-key

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ==========================================
# FILE UPLOAD SETTINGS
# ==========================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=csv,xlsx,xls,json
UPLOAD_DIR=uploads/
TEMP_DIR=temp/

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ==========================================
# EXTERNAL APIs
# ==========================================
# Currency Exchange API
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# Business Intelligence APIs
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_AI_FEATURES=true
ENABLE_ERP_SYNC=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_REAL_TIME_UPDATES=true

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://neuralbi.vercel.app
CORS_ALLOW_CREDENTIALS=true

# Development Database (separate from production)
DEV_DATABASE_URL=sqlite:///data/neuralbi_dev.db

# ==========================================
# BACKUP & MAINTENANCE
# ==========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=backups/

# ==========================================
# PERFORMANCE TUNING
# ==========================================
CACHE_ENABLED=true
COMPRESSION_ENABLED=true
GZIP_COMPRESSION_LEVEL=6

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# ==========================================
# THIRD-PARTY INTEGRATIONS
# ==========================================
# Slack Integration
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_BOT_TOKEN=your-slack-bot-token

# Google Analytics
GA_TRACKING_ID=your-ga-tracking-id

# Stripe (for payments)
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret